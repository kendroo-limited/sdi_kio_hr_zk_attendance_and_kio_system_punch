    <record id="view_hr_employee_form_inherit_device" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.device</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <page name="hr_settings" position="inside">
                <group>
                    <group string="Biometric Settings" name="biometric_group">
                        <field name="device_id" string="Biometric Device ID"/>
                        <field name="device_password" string="Device Password"/>
                        <field name="device_card_id" string="Device Card ID"/>
                        <button name="action_remove_user_from_device"
                            string="Remove this employee from device"
                            type="object"
                            class="btn-danger"
                            confirm="Are you sure to remove this employee from biometric machine?"
                            invisible="not device_id" />
                    </group>
                </group>
            </page>
        </field>
    </record>

    <record id="view_res_company_form_inherit" model="ir.ui.view">
        <field name="name">res.company.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml"><!-- Extend the General Information notebook page -->
            <notebook position="inside">
                <page string="HR Employees"><!-- Add your custom fields or widgets here -->
                    <label for="employee_ids"/>
                    <field name="employee_ids" widget="many2many_tags"/><!-- <field name="employee_ids" widget="many2many_tags"/> -->
                </page>
            </notebook>
        </field>
    </record>

    <record id="action_biometric_scheduled" model="ir.actions.act_window">
        <field name="name">Biometric Scheduled Actions</field>
        <field name="res_model">ir.cron</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[("name", "in", ["Auto Checkout Cron", "Download Data Cron","Error device connection cron"])]</field>
        <field name="context">{'create': False}</field>
    </record>


    <menuitem id="zk_machine_menu" parent="hr_attendance.menu_hr_attendance_root" sequence="50" name="Biometric Manager" groups="kio_hr_zk_attendance.group_hr_attendance_zk"/>
    <menuitem id="zk_machine_sub_menu" parent="zk_machine_menu" name="Device Configuration" action="zk_machine_action" sequence="1" groups="kio_hr_zk_attendance.group_hr_attendance_zk"/>
    <menuitem id="hr_mail" name="HR Mail" parent="hr_attendance.menu_hr_attendance_settings" action="base.action_res_company_form" groups="kio_hr_zk_attendance.group_hr_attendance_zk"/>
    <menuitem id="biometric_scheduled_id" name="Cron Scheduler" parent="hr_attendance.menu_hr_attendance_settings" action="action_biometric_scheduled" groups="kio_hr_zk_attendance.group_hr_attendance_zk"/>

</odoo>
