    <record id="view_cron_jobs_search" model="ir.ui.view">
            <field name="name">cron.jobs.search</field>
            <field name="model">ir.cron</field>
            <field name="arch" type="xml">
                <search string="Search Cron Jobs">
                    <!-- Define search filters -->
                    <filter name="auto_checkout_cron" string="Auto Checkout Cron" domain="[('name', 'ilike', 'Auto Checkout Cron')]"/>
                    <filter name="download_data_cron" string="Download Data Cron" domain="[('name', 'ilike', 'Download Data Cron')]"/>
                    <filter name="error_device_connection_cron" string="Error device connection cron" domain="[('name', 'ilike', 'Error device connection cron')]"/>
                    <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                    <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
    </record>

    <record id="action_zk_report_daily_attendance" model="ir.actions.act_window">
        <field name="name">Attendance Analysis</field>
        <field name="res_model">zk.report.daily.attendance</field>
        <field name="view_mode">tree</field>
        <field name="context">{'search_default_my_attendance':1}</field>
        <field name="search_view_id" ref="view_zk_report_daily_attendance_search" />
    </record>

    <menuitem id="menu_zk_attendance_view" name="Device Attendance log" action="action_zk_report_daily_attendance" parent="zk_machine_menu" sequence="2" groups="hr_attendance.group_hr_attendance_manager"/>
